{
  "include": ["./index.ts"],
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["esnext", "dom"],
    "strict": true,
    "noUnusedLocals": false,
    "noImplicitReturns": true,
    "inlineSourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "watch": true
  },
  "exclude": [
    "node_modules"
  ]
}
